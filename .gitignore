# Python
backend/.venv/
__pycache__/
*.pyc
backend/jobora.db
*.db
# Uploaded résumés + application evidence (PII) — never publish. Keep only the placeholder.
backend/uploads/*
!backend/uploads/.gitkeep
uploads/

# Node
frontend/node_modules/
frontend/dist/

# E2E test artifacts — contain auth state (localStorage tokens) and screenshots.
# Never commit: these may include real JWTs from test runs against a live stack.
frontend/e2e/.artifacts/
frontend/test-results/

# Env — never commit real secrets/API keys
.env
**/.env
backend/.env
*.local

# OS / editor
.DS_Store
.vscode/
.idea/
