# Jobara — PRODUCTION environment template.
# Copy to .env (or set these in your platform's dashboard) and fill every value.
# Never commit the filled-in file.

# ============================================================
# REQUIRED — security. The app is insecure without these.
# ============================================================
# Long random string used to sign JWTs:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Fernet key encrypting stored portal credentials:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this invalidates all stored portal credentials.
CREDENTIAL_KEY=

# ============================================================
# REQUIRED — datastores (use managed services in production)
# ============================================================
# Managed Postgres (RDS / Neon / Supabase / Railway / Render).
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/jobara

# Managed Redis (Upstash / ElastiCache / Railway / Render). Shared cache —
# required to scale to multiple API replicas.
REDIS_URL=redis://HOST:6379/0

# ============================================================
# REQUIRED — public URLs / CORS
# ============================================================
# Your web app's public origin (used in emails + links).
APP_BASE_URL=https://app.jobara.com

# Allowed browser origins for the API (comma-separated). Set this to your web
# app origin(s). Only needed when the SPA and API are on different domains
# (same-origin nginx-proxy deploys can leave the default).
CORS_ORIGINS=https://app.jobara.com

# ============================================================
# REQUIRED in prod — email (so reset links/notifications are sent)
# ============================================================
SMTP_HOST=smtp.youremail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Jobara <no-reply@jobara.com>
SMTP_TLS=1
# Stop returning reset tokens in API responses once real email works:
EXPOSE_RESET_TOKEN=0

# ============================================================
# OPTIONAL — more job sources (free keys widen India/Dubai/Singapore coverage)
# ============================================================
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
GREENHOUSE_BOARDS=
LEVER_COMPANIES=

# ============================================================
# OPTIONAL — tuning / logging
# ============================================================
JOB_CACHE_TTL=900
PROVIDER_TIMEOUT=15
PROVIDER_MIN_INTERVAL=1.0
RESET_TOKEN_TTL_MINUTES=30
LOG_LEVEL=INFO

# ============================================================
# OPTIONAL — AI (Phase 3; heuristics used when unset)
# ============================================================
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# ============================================================
# Docker-compose Postgres bootstrap (only if you run the bundled db service
# instead of a managed DB). Ignored when DATABASE_URL points elsewhere.
# ============================================================
POSTGRES_USER=jobara
POSTGRES_PASSWORD=
POSTGRES_DB=jobara
