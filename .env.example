# Copy to .env and fill in. docker-compose reads this file.
# NOTE: There are NO secret defaults in code. In production the app REFUSES to
# start unless JWT_SECRET and CREDENTIAL_KEY are set to valid, non-default values.

# --- Environment ---
# development = ephemeral dev secrets auto-generated (local only)
# production  = secrets REQUIRED; startup fails if missing/invalid
JOBORA_ENV=development

# --- Security (REQUIRED in production; no defaults) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_KEY=
JWT_EXPIRE_MINUTES=10080

# --- Admin bootstrap (REQUIRED to create an admin; no default account) ---
# If unset, NO admin is seeded. A seeded admin must change its password on first login.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Rate limiting (Redis-backed; in-memory fallback if no REDIS_URL) ---
RATE_LIMIT_ENABLED=1
RL_LOGIN_PER_MIN=10
RL_REGISTER_PER_HOUR=10
RL_APPLY_PER_DAY=30
RL_APPLY_BURST_PER_MIN=3
RL_SEARCH_PER_MIN=30

# --- Postgres (compose wires DATABASE_URL from these) ---
POSTGRES_USER=jobara
POSTGRES_PASSWORD=change-me
POSTGRES_DB=jobara
# Or set DATABASE_URL directly (managed DB). postgres:// is auto-normalized.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/jobara

# --- Cache (shared rate-limit + job cache across replicas) ---
REDIS_URL=

# --- App ---
APP_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
APP_VERSION=beta

# --- Cloud storage for resumes + evidence (S3 / Cloudflare R2 / MinIO) ---
# Local disk is used when S3_BUCKET is empty. In production set a bucket so
# resumes + confirmation screenshots persist across deploys/replicas.
S3_BUCKET=
S3_ENDPOINT_URL=        # leave empty for AWS; set for R2/MinIO (e.g. https://<acct>.r2.cloudflarestorage.com)
S3_REGION=us-east-1
S3_PRESIGN_TTL=900
AWS_ACCESS_KEY_ID=      # read by boto3
AWS_SECRET_ACCESS_KEY=

# --- Monitoring ---
SENTRY_DSN=                         # error tracking (gated; empty = off)
SENTRY_TRACES_SAMPLE_RATE=0.1
POSTHOG_API_KEY=                    # product analytics (gated; empty = off)
POSTHOG_HOST=https://us.i.posthog.com

# --- Closed beta ---
BETA_INVITE_REQUIRED=0              # 1 = registration requires a valid invite code

# --- Email (optional; console fallback if unset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Jobora <no-reply@jobara.app>
SMTP_TLS=1
# EXPOSE_RESET_TOKEN: include raw reset token in API response (dev only).
# Default is 0 (off). Set to 1 ONLY in local dev without a real email backend.
# NEVER set to 1 on a public or staging deployment.
EXPOSE_RESET_TOKEN=0

# --- Job providers (optional) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
# JSearch (RapidAPI → Google for Jobs): free RapidAPI key. Broad India + remote +
# internship coverage. The ONLY active provider with India coverage — disabled
# (returns nothing) until JSEARCH_API_KEY is set, so without it discovery shows
# only US/EU ATS boards (Stripe/Notion/Ramp). Get a free key:
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch (Basic = 200 req/month).
JSEARCH_API_KEY=
JSEARCH_HOST=jsearch.p.rapidapi.com
JSEARCH_COUNTRY=in                 # ISO-2 country always sent to JSearch (India)
JSEARCH_DEFAULT_LOCATION=India     # anchor location-less searches to India
JSEARCH_DEFAULT_QUERY=             # empty → India-first priority-domain default
GREENHOUSE_BOARDS=
LEVER_COMPANIES=
ASHBY_BOARDS=                  # comma-separated Ashby board names (official public API)
# Workable discovery needs the operator's AUTHORIZED account token + subdomains
# (Workable has no free public API). Disabled until both are set.
WORKABLE_TOKEN=
WORKABLE_SUBDOMAINS=
# Internshala / Wellfound: DISABLED unless an AUTHORIZED source is configured
# (official API / partner / licensed feed). No scraping — their robots.txt
# disallows the job paths. Expect a JSON feed.
INTERNSHALA_FEED_URL=
INTERNSHALA_FEED_TRUSTED=0
WELLFOUND_FEED_URL=
WELLFOUND_FEED_TRUSTED=0

# --- Aggregator tuning ---
JOB_CACHE_TTL=900
PROVIDER_TIMEOUT=15
PROVIDER_MIN_INTERVAL=1.0

# --- AI (optional — heuristics used when unset) ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# --- Live apply automation (opt-in; two guards BOTH required) ---
# Guard 1 — this env var:
#   JOBORA_LIVE=1 enables the submission code path.
# Guard 2 — Chromium installed:
#   Run `playwright install chromium` (local) or set INSTALL_BROWSERS=1 at
#   Docker build time. Without a Chromium binary on disk, live_ready() returns
#   False even when JOBORA_LIVE=1 ("Playwright Chromium is not installed").
# Both guards must be satisfied for the "Live mode is OFF" banner to disappear
# and for approving a job to trigger a real submission instead of "Manual Apply Required".
JOBORA_LIVE=0
