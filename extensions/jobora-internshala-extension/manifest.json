{
  "manifest_version": 3,
  "name": "Jobora — Internshala Copilot",
  "version": "1.0.0",
  "description": "Honest resume-match scoring, AI cover letters + application autofill for Internshala internships & jobs.",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://internshala.com/*",
    "https://*.internshala.com/*",
    "https://jobara-api.onrender.com/*",
    "https://*.jobora.app/*",
    "https://*.jobara.app/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://internshala.com/*",
        "https://*.internshala.com/*"
      ],
      "js": [
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Jobora — Internshala",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://internshala.com/*", "https://*.internshala.com/*"]
    }
  ]
}
