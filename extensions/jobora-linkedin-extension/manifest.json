{
  "manifest_version": 3,
  "name": "Jobora — LinkedIn Integration",
  "version": "1.0.0",
  "description": "Score LinkedIn jobs against your resume and save them to Jobora — instantly.",
  "minimum_chrome_version": "111",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:8000/*",
    "https://*.jobora.app/*",
    "https://*.jobara.app/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Jobora"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
