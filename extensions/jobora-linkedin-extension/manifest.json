{
  "manifest_version": 3,
  "name": "Jobora — Job Application Copilot",
  "version": "1.1.0",
  "description": "Honest resume-match scoring + one-click application autofill across LinkedIn, Naukri, Indeed & Internshala.",
  "minimum_chrome_version": "111",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.naukri.com/*",
    "https://*.indeed.com/*",
    "https://internshala.com/*",
    "https://jobara-api.onrender.com/*",
    "http://localhost:8000/*",
    "https://*.jobora.app/*",
    "https://*.jobara.app/*",
    "https://starconsulting.in/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.naukri.com/*",
        "https://*.indeed.com/*",
        "https://internshala.com/*"
      ],
      "js": [
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Jobora"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
